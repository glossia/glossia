---
import HeaderLink from './HeaderLink.astro';
import Logo from "./Logo.astro"
import { siteTitle } from '../constants';
---

<header>
	<nav class="navigation">
		<Logo size="30"/>
		<span class="title">Glossia</span>
	</nav>
</header>

<style>
	.navigation {
		display: flex;
		flex-direction: row;
		align-items: center;

	}

	.title {
		font-weight: var(--font-weight-6);
		margin-left: var(--size-2);
	}
</style>
