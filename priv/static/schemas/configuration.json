{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://glossia.ai/schemas/configuration.json",
  "type": "object",
  "description": "The configuration for a for a group of content",
  "properties": {
    "languages": {
      "description": "Source and target languages for a the components in this configuration.",
      "type": "object",
      "properties": {
        "source": {
          "$ref": "https://glossia.ai/schemas/language.json"
        },
        "target": {
          "type": "array",
          "items": [
            {
              "$ref": "https://glossia.ai/schemas/language.json"
            }
          ]
        }
      },
      "required": ["source", "target"]
    },
    "files": {
      "description": "A wildcard pattern to obtain the files to be translated.",
      "type": "string"
    }
  },
  "required": ["languages", "files"]
}
