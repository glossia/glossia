{
  "emmet.includeLanguages": {
    "phoenix-heex": "html"
  },
  "tailwindCSS.includeLanguages": {
    "elixir": "html",
    "phoenix-heex": "html"
  },
  "deno.enablePaths": ["priv/static/runner"],
  "deno.config": "priv/static/runner/deno.jsonc",
  "deno.enable": true,
  "deno.lint": true,
  "[typescript]": { 
    "editor.defaultFormatter": "denoland.vscode-deno", 
    "editor.formatOnSave": true 
  },
  "[javascript]": { 
    "editor.defaultFormatter": "denoland.vscode-deno", 
    "editor.formatOnSave": true 
  },
  "[elixir]": {
    "editor.formatOnSave": true,
    "editor.defaultFormatter": "JakeBecker.elixir-ls"
  },
  "files.associations": {
    "*.heex": "phoenix-heex",
  },
  "[phoenix-heex]": {
    "editor.formatOnSave": true,
    "editor.defaultFormatter": "JakeBecker.elixir-ls"
  },
}