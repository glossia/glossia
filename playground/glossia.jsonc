{
    "languages": {
        "source": "en",
        "target": ["es", "it", "de"]
    },
    "files": "posts/*/{language}.md",
    "context": "This is a context that applies to all the languages"
}

{
    "languages": {
        "source": "en",
        "target": ["es", "it", "de"]
    },
    "files": "posts/*/{language}.md",
    "context": {
        "*": "This is a context for all the languages",
        "it": "This is context only for italian",
        "it,de": "this is context only for it, and de"
    }
}

