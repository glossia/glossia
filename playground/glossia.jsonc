}


{
    "files": "*/{language}.md",
    "context": {
      "*": "This is a blog for the ecommerce platform, the content are blog posts that are targetting",
      "it,de": "This blog is for the European market, and therefore, people are more concerned about privacty and regulartions ke"
    }
}
**/


