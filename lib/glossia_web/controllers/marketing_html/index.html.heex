                stroke-width="2"
                stroke-miterlimit="10"
                stroke-linecap="round"
                stroke-linejoin="round"
              />
            </svg>
            Watch free demo
          </a> --%>
      </div>

      <p class="mt-8 text-base text-gray-500 font-inter">
        Forged from experience with Industry Leaders
      </p>

