<!DOCTYPE html>
<html>
<head>
<meta charset="utf-8" />
<meta name="viewport" content="width=1200" />
<link rel="stylesheet" href="https://fonts.googleapis.com/css2?family=Source+Serif+4:ital,opsz,wght@0,8..60,400;0,8..60,600;0,8..60,700;1,8..60,400&display=swap" />
<style>
  * { margin: 0; padding: 0; box-sizing: border-box; }

  body {
    width: 1200px;
    height: 630px;
    font-family: 'Source Serif 4', Georgia, serif;
    background: #faf8f5;
    color: #1c1917;
    display: flex;
    flex-direction: column;
    overflow: hidden;
    position: relative;
  }

  /* Gradient accent strip - explicit width to fill 1200px regardless of viewport */
  .accent-bar {
    width: 1200px;
    height: 6px;
    flex-shrink: 0;
    background: linear-gradient(90deg, #6d3cc4 0%, #7c3aed 30%, #f59e0b 70%, #fb923c 100%);
  }

  /* Large decorative gradient orb, bottom-right */
  .orb {
    position: absolute;
    right: -80px;
    bottom: -120px;
    width: 480px;
    height: 480px;
    border-radius: 50%;
    background: radial-gradient(circle at 40% 40%, rgba(124, 58, 237, 0.12), rgba(245, 158, 11, 0.06) 60%, transparent 80%);
    filter: blur(50px);
  }

  /* Subtle geometric rectangles like the homepage hero */
  .geo {
    position: absolute;
    border-radius: 10px;
    pointer-events: none;
  }
  .geo-1 {
    top: 60px;
    right: 80px;
    width: 140px;
    height: 140px;
    border: 1.5px solid rgba(124, 58, 237, 0.15);
  }
  .geo-2 {
    top: 140px;
    right: 20px;
    width: 120px;
    height: 120px;
    border: 1.5px solid rgba(245, 158, 11, 0.12);
  }
  .geo-3 {
    bottom: 100px;
    right: 140px;
    width: 100px;
    height: 100px;
    border: 1px solid rgba(124, 58, 237, 0.08);
  }

  /* Main layout */
  .main {
    flex: 1;
    display: flex;
    flex-direction: column;
    justify-content: center;
    padding: 0 80px;
    gap: 24px;
    position: relative;
    z-index: 1;
  }

  .logo-img {
    width: 64px;
    height: 64px;
    border-radius: 14px;
  }

  .badge {
    display: inline-flex;
    align-self: flex-start;
    background: rgba(124, 58, 237, 0.08);
    color: #6d3cc4;
    font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', sans-serif;
    font-size: 15px;
    font-weight: 600;
    padding: 6px 18px;
    border-radius: 20px;
    letter-spacing: 0.04em;
    text-transform: capitalize;
    border: 1px solid rgba(124, 58, 237, 0.15);
  }

  .title {
    font-size: 56px;
    font-weight: 700;
    line-height: 1.12;
    color: #1c1917;
    max-width: 900px;
    overflow: hidden;
    display: -webkit-box;
    -webkit-line-clamp: 3;
    -webkit-box-orient: vertical;
  }

  .description {
    font-size: 24px;
    font-weight: 400;
    line-height: 1.5;
    color: #5c564e;
    max-width: 820px;
    overflow: hidden;
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
  }

  /* Divider */
  .divider {
    width: 1200px;
    height: 1px;
    background: #e4e0d9;
    flex-shrink: 0;
  }

  /* Footer */
  .footer {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 20px 80px 36px 80px;
    position: relative;
    z-index: 1;
  }

  .brand {
    display: flex;
    align-items: center;
    gap: 12px;
  }

  .brand-logo {
    width: 32px;
    height: 32px;
    border-radius: 7px;
  }

  .brand-name {
    font-size: 22px;
    font-weight: 600;
    color: #1c1917;
    letter-spacing: -0.01em;
  }

  .domain {
    font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', sans-serif;
    font-size: 17px;
    font-weight: 500;
    color: #a09a91;
  }
</style>
</head>
<body>
  <div class="accent-bar"></div>
  <div class="orb"></div>
  <div class="geo geo-1"></div>
  <div class="geo geo-2"></div>
  <div class="geo geo-3"></div>

  <div class="main">
    <img class="logo-img" src="data:image/png;base64,<%= Base.encode64(File.read!(Path.join(:code.priv_dir(:glossia), "static/images/logo-rounded.png"))) %>" alt="" />
    <%= if category != "" and category != "home" do %>
      <div class="badge"><%= category %></div>
    <% end %>
    <div class="title"><%= title %></div>
    <%= if description != "" do %>
      <div class="description"><%= description %></div>
    <% end %>
  </div>

  <div class="divider"></div>

  <div class="footer">
    <div class="brand">
      <img class="brand-logo" src="data:image/png;base64,<%= Base.encode64(File.read!(Path.join(:code.priv_dir(:glossia), "static/images/logo-rounded.png"))) %>" alt="" />
      <div class="brand-name">Glossia</div>
    </div>
    <div class="domain">glossia.ai</div>
  </div>
</body>
</html>
