    </div>
  </div>
</section>

<section id="config" class="section">
  <div class="container">
    <h2 class="reveal">{gettext("The more specific the context, the closer to the content")}</h2>
    <p class="muted lead reveal">
      {gettext(
        "Global definitions on Glossia set the baseline for your organization. Project-level context narrows the scope. The result: every agent gets exactly the right instructions without you repeating yourself."
      )}
    </p>
    <div class="config-grid">
      <div class="card config-card reveal">
        <h3>{gettext("Project context (repository example)")}</h3>
        <p>
          {gettext(
            "GLOSSIA.md files sit alongside your content. They carry instructions, tone guidance, and per-language overrides that scope context to exactly where it is needed."
          )}
        </p>
        <div class="file-tree">
          <ul>
            <li><span class="highlight">GLOSSIA.md</span></li>
            <li>
              <span class="dir">LANGUAGE/</span>
              <ul>
                <li><span class="file">es.md</span></li>
                <li><span class="file">ja.md</span></li>
              </ul>
            </li>
            <li>
              <span class="dir">docs/</span>
              <ul>
                <li><span class="highlight">GLOSSIA.md</span></li>
                <li>
                  <span class="dir">guide/</span>
                  <ul>
                    <li><span class="file">intro.md</span></li>
                  </ul>
                </li>
              </ul>
            </li>
          </ul>
        </div>
      </div>
      <div class="card config-card reveal">
        <h3>{gettext("On Glossia")}</h3>
        <p>
          {gettext(
            "Voices, glossaries, audience profiles, and style rules live on the platform. They are shared across every project in your organization and versioned so nothing gets lost."
          )}
        </p>
        <div class="file-tree">
          <ul>
            <li>
              <span class="dir">{gettext("Organization")}</span>
              <ul>
                <li><span class="highlight">{gettext("Voices")}</span></li>
                <li><span class="highlight">{gettext("Glossary")}</span></li>
                <li>
                  <span class="dir">{gettext("Project A")}</span>
                  <ul>
                    <li><span class="file">{gettext("Linked repo")}</span></li>
                  </ul>
                </li>
                <li>
                  <span class="dir">{gettext("Project B")}</span>
                  <ul>
                    <li><span class="file">{gettext("Linked repo")}</span></li>
                  </ul>
                </li>
              </ul>
            </li>
          </ul>
        </div>
      </div>
    </div>
  </div>
</section>

